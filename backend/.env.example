# 后端环境变量
# 复制本文件为 .env 后填写

# 应用配置
APP_NAME=A-Share Screener
DEBUG=false
HOST=0.0.0.0
PORT=8000

# 数据库
DATABASE_URL=sqlite:///./data/screener.db

# 数据源配置
# mock = 模拟数据（稳定演示）
# akshare = 真实 A 股数据（来自东方财富公开接口）
SCREENER_PROVIDER=mock

# AI 顾问配置（兼容 OpenAI 格式）
AI_ADVISOR_ENABLED=false
AI_ADVISOR_API_URL=https://api.openai.com/v1/chat/completions
AI_ADVISOR_API_KEY=your-api-key-here
AI_ADVISOR_MODEL=gpt-4o-mini
AI_ADVISOR_TEMPERATURE=0.7
# thinking_effort 由模型自身返回，程序只透传
