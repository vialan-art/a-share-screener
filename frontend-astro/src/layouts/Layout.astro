---
import { ClientRouter } from 'astro:transitions';
import AngelBackground from '../components/AngelBackground.astro';
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
  active?: string;
}

const { title = 'Pizarro · 选股', description = 'A professional A-share stock screener.', active = '' } = Astro.props;

const navItems = [
  { href: '/', label: '概览', labelEn: 'Overview' },
  { href: '/screener/', label: '选股池', labelEn: 'Screener' },
  { href: '/portfolio/', label: '组合', labelEn: 'Portfolio' },
  { href: '/backtest/', label: '回测', labelEn: 'Backtest' },
  { href: '/history/', label: '历史', labelEn: 'History' },
  { href: '/logs/', label: '日志', labelEn: 'Logs' },
  { href: '/advisor/', label: 'Advisor', labelEn: 'AI' },
  { href: '/settings/', label: '设置', labelEn: 'Settings' },
];

function isActive(href: string, current: string) {
  if (href === '/') return current === '/';
  return current.startsWith(href.replace(/\/$/, ''));
}
---

<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <ClientRouter />
  </head>
  <body class="min-h-screen">
    <AngelBackground />
    <div class="grain-overlay" aria-hidden="true"></div>

    <header class="fixed top-0 left-0 right-0 z-50 px-6 lg:px-10 py-5">
      <div class="max-w-7xl mx-auto flex items-center justify-between">
        <a href="/" class="group flex items-center gap-3">
          <span class="w-8 h-8 rounded-full bg-slate-100/90 text-slate-950 flex items-center justify-center text-sm font-bold font-display">P</span>
          <span class="font-display text-xl tracking-tight text-slate-50">Pizarro</span>
        </a>
        <nav class="hidden md:flex items-center gap-1">
          {navItems.map((item) => {
            const itemActive = isActive(item.href, active);
            return (
              <a
                href={item.href}
                class={`group relative px-4 py-2 text-[12px] tracking-wide transition-colors duration-300 ${
                  itemActive ? 'text-slate-50' : 'text-slate-500 hover:text-cyan-300'
                }`}
              >
                {item.label}
                <span
                  class={`absolute bottom-1 left-4 right-4 h-[1px] bg-gradient-to-r from-cyan-300 to-slate-400 rounded-full transition-transform duration-300 origin-left ${
                    itemActive ? 'scale-x-100' : 'scale-x-0 group-hover:scale-x-100'
                  }`}
                />
              </a>
            );
          })}
        </nav>
      </div>
    </header>

    <main class="relative z-10 min-h-screen pt-20">
      <div class="max-w-7xl mx-auto px-6 lg:px-10 pb-16">
        <slot />
      </div>
    </main>
  </body>
</html>
