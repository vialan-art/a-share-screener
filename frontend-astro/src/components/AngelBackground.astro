---
const { class: className = '' } = Astro.props;
---

<div class={`fixed inset-0 z-0 overflow-hidden ${className}`} aria-hidden="true">
  <svg class="absolute w-0 h-0">
    <defs>
      <filter id="liquid-distort" x="-30%" y="-30%" width="160%" height="160%">
        <feTurbulence
          type="fractalNoise"
          baseFrequency="0.005 0.012"
          numOctaves="3"
          result="noise"
          seed="8"
        />
        <feDisplacementMap
          in="SourceGraphic"
          in2="noise"
          scale="55"
          xChannelSelector="R"
          yChannelSelector="G"
        />
      </filter>

      <filter id="water-glow" x="-20%" y="-20%" width="140%" height="140%">
        <feGaussianBlur in="SourceGraphic" stdDeviation="1.5" result="blur" />
        <feColorMatrix
          in="blur"
          type="matrix"
          values="0.85 0 0 0 0.08  0 0.9 0 0 0.12  0 0 1.15 0 0.18  0 0 0 1 0"
          result="tinted"
        />
        <feMerge>
          <feMergeNode in="tinted" />
          <feMergeNode in="SourceGraphic" />
        </feMerge>
      </filter>
    </defs>
  </svg>

  <div
    class="absolute inset-0"
    style="
      background-image: url('/angel.png');
      background-size: contain;
      background-position: center center;
      background-repeat: no-repeat;
      filter: url(#water-glow) url(#liquid-distort);
      opacity: 0.9;
    "
  />

  <div
    class="absolute inset-0"
    style="
      background: radial-gradient(ellipse at 50% 25%, transparent 0%, rgba(2, 4, 8, 0.35) 45%, rgba(2, 4, 8, 0.75) 100%);
    "
  />

  <div
    class="absolute inset-0"
    style="
      background: linear-gradient(180deg, rgba(2, 6, 23, 0.35) 0%, rgba(2, 4, 8, 0.05) 35%, rgba(2, 4, 8, 0.35) 100%);
    "
  />

  <div
    class="absolute inset-0 animate-caustics"
    style="
      background:
        radial-gradient(ellipse at 20% 30%, rgba(125, 211, 252, 0.35) 0%, transparent 35%),
        radial-gradient(ellipse at 80% 45%, rgba(196, 181, 253, 0.22) 0%, transparent 40%),
        radial-gradient(ellipse at 50% 20%, rgba(240, 249, 255, 0.2) 0%, transparent 50%),
        radial-gradient(ellipse at 35% 60%, rgba(56, 189, 248, 0.15) 0%, transparent 45%);
      mix-blend-mode: screen;
    "
  />

  <div
    class="absolute inset-0 animate-liquid-surface pointer-events-none"
    style="
      background: repeating-linear-gradient(
        0deg,
        transparent 0px,
        rgba(125, 211, 252, 0.06) 1px,
        transparent 5px
      );
      mix-blend-mode: overlay;
    "
  />

  <div
    class="absolute inset-0 animate-liquid-surface-reverse pointer-events-none"
    style="
      background: repeating-linear-gradient(
        90deg,
        transparent 0px,
        rgba(255, 255, 255, 0.04) 1px,
        transparent 7px
      );
      mix-blend-mode: overlay;
    "
  />

  <div
    class="absolute inset-0 pointer-events-none"
    style="
      background:
        conic-gradient(from 180deg at 50% 0%, transparent 0deg, rgba(240, 249, 255, 0.18) 8deg, rgba(56, 189, 248, 0.28) 24deg, rgba(240, 249, 255, 0.14) 40deg, transparent 52deg);
      mix-blend-mode: screen;
      transform-origin: top center;
    "
  />

  <div
    class="absolute top-0 left-1/2 -translate-x-1/2 w-[1000px] h-[110vh] animate-beam"
    style="
      background: radial-gradient(ellipse at 50% 0%, rgba(255, 255, 255, 0.3) 0%, rgba(56, 189, 248, 0.18) 16%, transparent 45%);
      filter: blur(20px);
      mix-blend-mode: screen;
    "
  />

  <div
    class="absolute inset-0"
    style="
      background:
        linear-gradient(180deg, rgba(2, 4, 8, 0.35) 0%, transparent 15%, transparent 50%, rgba(2, 4, 8, 0.75) 100%);
    "
  />

  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="bubble" style="left: 12%; bottom: -20px; width: 8px; height: 8px; animation-delay: 0s;" />
    <div class="bubble" style="left: 25%; bottom: -40px; width: 5px; height: 5px; animation-delay: 2.5s;" />
    <div class="bubble" style="left: 58%; bottom: -30px; width: 10px; height: 10px; animation-delay: 1.2s;" />
    <div class="bubble" style="left: 76%; bottom: -50px; width: 6px; height: 6px; animation-delay: 4s;" />
    <div class="bubble" style="left: 38%; bottom: -25px; width: 4px; height: 4px; animation-delay: 5.5s;" />
    <div class="bubble" style="left: 85%; bottom: -35px; width: 7px; height: 7px; animation-delay: 3.2s;" />
    <div class="bubble" style="left: 48%; bottom: -60px; width: 9px; height: 9px; animation-delay: 6s;" />
  </div>

  <div
    class="absolute inset-0 animate-ripple pointer-events-none"
    style="
      background: radial-gradient(circle at 50% 40%, transparent 20%, rgba(56, 189, 248, 0.05) 40%, transparent 60%);
      mix-blend-mode: screen;
    "
  />

  <div
    class="absolute inset-0 opacity-[0.04]"
    style="
      background-image: url(\"data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.5'/%3E%3C/svg%3E\");
    "
  />

  <div
    class="absolute inset-0"
    style="
      background-image:
        linear-gradient(rgba(56, 189, 248, 0.015) 1px, transparent 1px),
        linear-gradient(90deg, rgba(56, 189, 248, 0.015) 1px, transparent 1px);
      background-size: 100px 100px;
      mask-image: radial-gradient(ellipse at 50% 40%, black 0%, transparent 70%);
      -webkit-mask-image: radial-gradient(ellipse at 50% 40%, black 0%, transparent 70%);
    "
  />
</div>

<style is:global>
  @keyframes liquid-breathe {
    0%, 100% { transform: scale(1) translate(0, 0); }
    25% { transform: scale(1.015) translate(-3px, 2px); }
    50% { transform: scale(1.01) translate(2px, -2px); }
    75% { transform: scale(1.02) translate(3px, 1px); }
  }

  @keyframes caustics {
    0%, 100% { transform: translate(0, 0) rotate(0deg) scale(1); opacity: 0.8; }
    33% { transform: translate(-50px, 25px) rotate(2deg) scale(1.1); opacity: 1; }
    66% { transform: translate(35px, -35px) rotate(-1.5deg) scale(0.97); opacity: 0.85; }
  }

  @keyframes liquid-surface {
    0% { transform: translateY(0); opacity: 0.45; }
    50% { transform: translateY(-15px); opacity: 0.75; }
    100% { transform: translateY(0); opacity: 0.45; }
  }

  @keyframes liquid-surface-reverse {
    0% { transform: translateX(0); opacity: 0.3; }
    50% { transform: translateX(15px); opacity: 0.55; }
    100% { transform: translateX(0); opacity: 0.3; }
  }

  @keyframes beam {
    0%, 100% { opacity: 0.6; transform: translateX(-50%) scaleY(1); }
    50% { opacity: 0.95; transform: translateX(-50%) scaleY(1.06); }
  }

  @keyframes ripple {
    0%, 100% { transform: scale(1); opacity: 0.4; }
    50% { transform: scale(1.25); opacity: 0.65; }
  }

  @keyframes bubble-rise {
    0% { transform: translateY(0) scale(0.8); opacity: 0; }
    8% { opacity: 0.7; }
    92% { opacity: 0.4; }
    100% { transform: translateY(-120vh) scale(1.3); opacity: 0; }
  }

  .animate-liquid-breathe {
    animation: liquid-breathe 10s ease-in-out infinite;
  }

  .animate-caustics {
    animation: caustics 14s ease-in-out infinite;
  }

  .animate-liquid-surface {
    animation: liquid-surface 7s ease-in-out infinite;
  }

  .animate-liquid-surface-reverse {
    animation: liquid-surface-reverse 9s ease-in-out infinite;
  }

  .animate-beam {
    animation: beam 6s ease-in-out infinite;
  }

  .animate-ripple {
    animation: ripple 11s ease-in-out infinite;
  }

  .bubble {
    position: absolute;
    border-radius: 50%;
    background: radial-gradient(circle at 30% 30%, rgba(255, 255, 255, 0.8), rgba(125, 211, 252, 0.4) 50%, transparent 80%);
    box-shadow: 0 0 10px rgba(125, 211, 252, 0.4);
    animation: bubble-rise 16s ease-in infinite;
  }
</style>
